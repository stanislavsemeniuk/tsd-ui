{
  "name": "tsd-ui",
  "main": "packages/core/src/index.ts",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build --filter='./packages/*'",
    "test": "turbo run test --filter='./packages/*'",
    "lint": "turbo run lint --filter='./packages/*'",
    "typecheck": "turbo run typecheck --filter='./packages/*'",
    "docs": "npm run dev --workspace=@tsd-ui/docs",
    "docs:build": "turbo run build --filter='./packages/*' && npm run build --workspace=@tsd-ui/docs",
    "storybook": "npm run dev --workspace=@tsd-ui/storybook",
    "storybook:build": "turbo run build --filter='./packages/*' && npm run build --workspace=@tsd-ui/storybook",
    "format": "prettier --check './packages/**/*.{ts,tsx,js,json}'",
    "format:fix": "prettier --write './packages/**/*.{ts,tsx,js,json}'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "turbo": "^2.8.20",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}