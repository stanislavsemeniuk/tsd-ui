{
  "name": "@tsd-ui/table-controls",
  "description": "Table control contracts and hooks composing `@tsd-ui/core` logic with PatternFly table components.",
  "license": "Apache-2.0",
  "author": "The tsd-ui team",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsd-ui/tsd-ui.git",
    "directory": "packages/table-controls"
  },
  "homepage": "https://tsd-ui.github.io/tsd-ui/",
  "bugs": {
    "url": "https://github.com/tsd-ui/tsd-ui/issues"
  },
  "keywords": [
    "react",
    "patternfly",
    "typescript",
    "ui",
    "components"
  ],
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
