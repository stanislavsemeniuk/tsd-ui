{
  "name": "@tsd-ui/core",
  "description": "Shared types, components, hooks, and utilities — the foundation layer of tsd-ui.",
  "license": "Apache-2.0",
  "author": "The tsd-ui team",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsd-ui/tsd-ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://tsd-ui.github.io/tsd-ui/",
  "bugs": {
    "url": "https://github.com/tsd-ui/tsd-ui/issues"
  },
  "keywords": [
    "react",
    "patternfly",
    "typescript",
    "ui",
    "components"
  ],
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^29.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependencies": {
    "@patternfly/react-core": "^6.0.0",
    "@patternfly/react-icons": "^6.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
